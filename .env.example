# Copy to .env and fill from Firebase console → Project settings → Your apps → Web app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Firestore room document id (default: vibe-coding-recess). All visitors join this one room.
# VITE_ROOM_ID=
